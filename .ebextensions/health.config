option_settings:
  # Use enhanced health reporting so Beanstalk surfaces HTTP-level metrics
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  # Tell the load-balancer which path to use for health checks
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    Port: "5000"
    Protocol: HTTP
